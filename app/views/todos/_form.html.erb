<%= form_with(model: todo, class: "needs-validation") do |form| %>
  <% if todo.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% todo.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, "タイトル", class: "form-label fw-semibold" %>
    <%= form.text_field :title, class: "form-control", placeholder: "Todo のタイトル", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :body, "詳細・メモ", class: "form-label fw-semibold" %>
    <%= form.text_area :body, class: "form-control", rows: 4, placeholder: "メモを入力（任意）" %>
  </div>

  <div class="mb-3">
    <%= form.label :due_date, "期限日", class: "form-label fw-semibold" %>
    <%= form.date_field :due_date, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :tags, "タグ", class: "form-label fw-semibold" %>
    <%= form.text_field :tags, class: "form-control", placeholder: "仕事, 買い物, 勉強（カンマ区切り）" %>
    <div class="form-text">複数のタグはカンマで区切って入力してください。</div>
  </div>

  <div class="mb-4 form-check">
    <%= form.check_box :completed, class: "form-check-input" %>
    <%= form.label :completed, "完了", class: "form-check-label" %>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit todo.new_record? ? "作成する" : "更新する", class: "btn btn-primary" %>
    <%= link_to "キャンセル", todos_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

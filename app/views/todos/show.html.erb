<% content_for :title, @todo.title %>

<div class="card shadow-sm">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h4 class="mb-0"><%= @todo.title %></h4>
    <span class="badge <%= @todo.completed ? 'bg-success' : 'bg-secondary' %> fs-6">
      <%= @todo.completed ? '完了' : '未完了' %>
    </span>
  </div>
  <div class="card-body">
    <% if @todo.body.present? %>
      <p class="card-text"><%= simple_format @todo.body %></p>
      <hr>
    <% end %>

    <dl class="row mb-0">
      <dt class="col-sm-3">期限日</dt>
      <dd class="col-sm-9">
        <% if @todo.due_date %>
          <span class="badge <%= @todo.due_date < Date.today && !@todo.completed ? 'bg-danger' : 'bg-secondary' %>">
            <%= @todo.due_date.strftime("%Y年%m月%d日") %>
          </span>
        <% else %>
          <span class="text-muted">未設定</span>
        <% end %>
      </dd>

      <dt class="col-sm-3">タグ</dt>
      <dd class="col-sm-9">
        <% tags = @todo.tags.to_s.split(",").map(&:strip).reject(&:empty?) %>
        <% if tags.any? %>
          <% tags.each do |tag| %>
            <span class="badge bg-info text-dark me-1"><%= tag %></span>
          <% end %>
        <% else %>
          <span class="text-muted">なし</span>
        <% end %>
      </dd>
    </dl>
  </div>
  <div class="card-footer d-flex gap-2">
    <%= link_to "編集", edit_todo_path(@todo), class: "btn btn-primary btn-sm" %>
    <%= button_to @todo.completed ? "未完了に戻す" : "完了にする", toggle_todo_path(@todo),
          method: :patch, class: "btn btn-sm #{ @todo.completed ? 'btn-outline-secondary' : 'btn-success' }" %>
    <%= button_to "削除", @todo, method: :delete,
          class: "btn btn-danger btn-sm",
          data: { turbo_confirm: "削除してよろしいですか？" } %>
    <%= link_to "一覧へ戻る", todos_path, class: "btn btn-outline-secondary btn-sm ms-auto" %>
  </div>
</div>
